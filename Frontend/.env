# ── Women Safety System — Environment Variables ──────────────────────
# Copy this file to .env and fill in your real keys
# Never commit .env to git

# Google Maps API (for geocoding, nearby places)
# Get it from: https://console.cloud.google.com
# Enable: Maps JavaScript API, Places API, Geocoding API, Directions API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Twilio — for SMS alerts to family (international)
# Get it from: https://twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Fast2SMS — for SMS alerts (India, cheaper alternative to Twilio)
# Get it from: https://fast2sms.com
FAST2SMS_API_KEY=your_fast2sms_api_key

# Emergency contacts (comma separated with country code)
EMERGENCY_CONTACTS=+919125474036,+918287139346
